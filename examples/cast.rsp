; Numeric casts via (as T e).
;;! stdout: ok: cast
;;! exit: 0

(defn main [] -> i32
  (let [a: i64 (as i64 42)
        b: i32 (as i32 100i64)
        c: f64 (as f64 3)
        d: i32 (as i32 3.9)]
    (if (and (= a 42i64)
             (and (= b 100)
                  (and (= c 3.0) (= d 3))))
      (do (println "ok: cast") 0)
      (do (println "FAIL: cast") 1))))
